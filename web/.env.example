# (선택) Geocode — 농장 주소 → lat/lng (서버 전용, Kakao Local API)
# KAKAO_REST_API_KEY=

# (선택) 기상청 공공데이터 — 기상특보 PoC/배치 (서버 전용)
# data.go.kr WthrWrnInfoService + FcstZoneInfoService 활용신청 후 발급
# DATA_GO_KR_SERVICE_KEY=

# (선택) Playwright audit — 기본 http://localhost:3000 (dev 서버 실행 중)
# UI_VERIFY_BASE=http://127.0.0.1:3000

# (선택) LIVE read tier: `list` (default) | `legacy` (full decoded_json on list)
# NEXT_PUBLIC_LIVE_READ_TIER=list

# (선택) Health 수집 그룹 — farmKeyId 배열 JSON. 미설정 시 농장 목록을 반으로 나눔.
# HEALTH_COLLECTOR_GROUPS={"col-a":["FARM01/P00","FARM02/P00"],"col-b":["FARM06/P00"]}